{
  "name": "create-polystack",
  "version": "0.1.4",
  "description": "Scaffold polyglot projects (Java, Python, JS, TS, PHP) from Polystack templates.",
  "keywords": [
    "scaffold",
    "cli",
    "starter",
    "polyglot",
    "java",
    "python",
    "typescript",
    "php"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "create-polystack": "./bin/index.js",
    "polystack": "./bin/index.js"
  },
  "main": "./bin/index.js",
  "files": [
    "bin",
    "src",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/index.js",
    "prepack": "node scripts/prepack.mjs",
    "postpack": "node scripts/postpack.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "kleur": "^4.1.5",
    "mri": "^1.2.0"
  },
  "devDependencies": {
    "@polystack/core": "workspace:*",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
